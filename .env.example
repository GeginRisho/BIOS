# ==========================================
# BIOS GLOBAL ENVIRONMENT SETTINGS
# ==========================================

# 1. API GATEWAY ROUTING
GATEWAY_PORT=80
GATEWAY_HOST=localhost

# 2. JWT SECURITY CREDENTIALS
JWT_SECRET_KEY=bios_super_secret_signing_key_2026_jwt_token_auth
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# 3. RELATIONAL & TIME-SERIES DATABASES (POSTGRESQL + TIMESCALEDB)
POSTGRES_USER=bios_admin
POSTGRES_PASSWORD=bios_secure_pwd_2026
POSTGRES_DB=bios_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# 4. KNOWLEDGE GRAPH DATABASE (NEO4J)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=bios_graph_secure_2026

# 5. DOCUMENT STORAGE (MONGODB)
MONGO_USER=bios_mongo
MONGO_PASSWORD=bios_mongo_secure_2026
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_DB=bios_raw_db

# 6. VECTOR INDEX DB (QDRANT)
QDRANT_HOST=localhost
QDRANT_PORT=6333

# 7. SEARCH INDEX ENGINE (ELASTICSEARCH)
ELASTICSEARCH_HOST=http://localhost:9200

# 8. TASK BROKER & SESSION CACHE (REDIS)
REDIS_HOST=localhost
REDIS_PORT=6379

# 9. EVENT STREAMING BROKER (KAFKA)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# 10. AI LLM PROVIDERS CONFIGURATION
# Options: mock, openai, ollama
LLM_PROVIDER=mock
OPENAI_API_KEY=sk-proj-YOUR_API_KEY_HERE
OLLAMA_HOST=http://localhost:11434
LLM_MODEL=gpt-4o

# 11. CRAWLER POLICIES
DEFAULT_RATE_LIMIT_RPS=2
USER_AGENT=BIOS Planetary Intelligence Crawler (Mozilla/5.0 Compliance Engine)
